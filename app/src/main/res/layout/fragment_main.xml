<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/fragment_root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".fragments.main.MainFragment">

    <Space
        android:layout_width="match_parent"
        android:layout_height="20dp" />

    <LinearLayout
        android:orientation="horizontal"
        android:layout_margin="20dp"
        android:layout_width="match_parent"
        android:layout_height="50dp">

        <TextView
            android:id="@+id/text_view"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:text="@string/select_role"
            android:textColor="@color/primary_textcolor"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/select_role_tip"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:padding="15dp"
            android:layout_margin="0dp"
            app:srcCompat="@drawable/info2" />
    </LinearLayout>

    <RadioGroup
        android:id="@+id/radioGroupMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="0dp"
        android:layout_marginStart="30dp"
        android:layout_marginBottom="5dp"
        android:gravity="center_horizontal"
        app:layout_constraintTop_toBottomOf="@+id/text_view">

        <LinearLayout
            android:id="@+id/admin_row"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:layout_width="match_parent"
            android:layout_height="50dp">

            <RadioButton
                android:id="@+id/admin_button"
                android:clickable="false"
                android:focusable="false"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/admin"
                android:textColor="@color/primary_textcolor"
                android:textSize="20sp"/>

            <ImageView
                android:id="@+id/admin_tip"
                android:clickable="true"
                android:focusable="true"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:padding="15dp"
                android:layout_margin="0dp"
                app:srcCompat="@drawable/info2" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/supervisor_row"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:layout_width="match_parent"
            android:layout_height="50dp">

            <RadioButton
                android:id="@+id/supervisor_button"
                android:clickable="false"
                android:focusable="false"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/supervisor"
                android:textColor="@color/primary_textcolor"
                android:textSize="20sp"/>

            <ImageView
                android:id="@+id/supervisor_tip"
                android:clickable="true"
                android:focusable="true"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:padding="15dp"
                android:layout_margin="0dp"
                app:srcCompat="@drawable/info2" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/enumerator_row"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:layout_width="match_parent"
            android:layout_height="50dp">

            <RadioButton
                android:id="@+id/enumerator_button"
                android:clickable="false"
                android:focusable="false"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/enumerator"
                android:textColor="@color/primary_textcolor"
                android:textSize="20sp"/>

            <ImageView
                android:id="@+id/enumerator_tip"
                android:clickable="true"
                android:focusable="true"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:padding="15dp"
                android:layout_margin="0dp"
                app:srcCompat="@drawable/info2" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/data_collector_row"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:layout_width="match_parent"
            android:layout_height="50dp">

            <RadioButton
                android:id="@+id/data_collector_button"
                android:clickable="false"
                android:focusable="false"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/data_collector"
                android:textColor="@color/primary_textcolor"
                android:textSize="20sp"/>

            <ImageView
                android:id="@+id/data_collector_tip"
                android:clickable="true"
                android:focusable="true"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:padding="15dp"
                android:layout_margin="0dp"
                app:srcCompat="@drawable/info2" />
        </LinearLayout>
    </RadioGroup>

    <Space
        android:layout_weight="1"
        android:layout_width="match_parent"
        android:layout_height="0dp" />

    <Button
        android:id="@+id/sign_in_button"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:textColor="@color/white"
        android:text="@string/sign_in" />

    <Button
        android:id="@+id/sign_up_button"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:textColor="@color/white"
        android:text="@string/not_registered" />

    <TextView
        android:id="@+id/webpage_link"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginBottom="10dp"
        android:text="https://www.GPSSample.org"
        android:textColor="@color/link_color"
        android:gravity="center"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true"
        android:padding="8dp"/>

    <TextView
        android:id="@+id/app_version_text_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="14sp"
        android:text="App Version 1.0.0 #105"/>

    <TextView
        android:id="@+id/db_version_text_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="20dp"
        android:gravity="center"
        android:textSize="14sp"
        android:text="Database Version #306"/>

</androidx.appcompat.widget.LinearLayoutCompat>